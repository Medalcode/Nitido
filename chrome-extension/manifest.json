{
  "manifest_version": 3,
  "name": "Nitido",
  "version": "0.1.0",
  "description": "Descifra términos y condiciones, contratos y documentos legales al español simple.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Nitido - Analizar documento"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
